{
  "$schema": "https://schema.stryker-mutator.io/stryker-config.schema.json",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "testRunner_ms": {
    "configFile": "vitest.config.ts"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/utils/hash.ts",
    "src/utils/jwt.ts",
    "src/utils/otp.ts",
    "src/middleware/auth.ts"
  ],
  "tempDirName": "stryker-tmp",
  "cleanTempDir": true
}
