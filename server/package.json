    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.17.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4",
    "prisma": "6.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
