{
  "name": "spms-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev --prefix server\" --names \"frontend,backend\" --prefix-colors \"cyan,magenta\"",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev --prefix server",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "npm run migrate --prefix server",
    "db:seed": "npm run seed --prefix server",
    "install:all": "npm install && npm install --prefix server",
    "clean:dist": "rimraf dist && rimraf server/dist",
    "build:prod": "npm run clean:dist && vite build && npm run build --prefix server",
    "start": "node server/dist/index.js",
    "test": "vitest run --config vitest.config.test.js",
    "test:watch": "vitest --config vitest.config.test.js",
    "test:ui": "vitest --ui --config vitest.config.test.js"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.8.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "vitest": "^4.1.0",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  }
}
